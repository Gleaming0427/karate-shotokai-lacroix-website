---
import { getCollection } from 'astro:content';

const events = await getCollection('evenements');
events.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<section class="section" id="evenements">
  <div class="container">
    <h2 class="section-title">Événements à venir</h2>

    {events.length === 0 ? (
      <p style="text-align: center; color: var(--color-text-soft);">Aucun événement à venir.</p>
    ) : (
      <div class="events-scroll">
        {events.map(event => (
          <article class={`event-card ${!event.data.image ? 'event-card-text' : ''}`} id={event.data.image ? `event-${event.id}` : undefined} style={event.data.image ? 'cursor: pointer;' : ''}>
            {event.data.image && (
              <img src={event.data.image} alt={event.data.title} loading="lazy" />
            )}
            <div class="event-card-body">
              <span class="event-tag">{event.data.tag}</span>
              <h3>{event.data.title}</h3>
              <p>{event.data.body}</p>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</section>

<!-- Lightbox pour le premier événement avec image -->
{events.filter(e => e.data.image).length > 0 && (
  <>
    <div class="modal-overlay" id="modal-overlay">
      <div class="modal-content">
        <button class="modal-close" id="modal-close">&times;</button>
        <img src="" alt="" id="modal-img" />
      </div>
    </div>
    <script>
      const overlay = document.getElementById('modal-overlay')!;
      const close = document.getElementById('modal-close')!;
      const modalImg = document.getElementById('modal-img') as HTMLImageElement;
      document.querySelectorAll('.event-card img').forEach(img => {
        img.closest('.event-card')?.addEventListener('click', () => {
          const src = img.getAttribute('src') || '';
          modalImg.src = src;
          overlay.classList.add('open');
          document.body.style.overflow = 'hidden';
        });
      });
      function closeModal() {
        overlay.classList.remove('open');
        document.body.style.overflow = '';
      }
      close.addEventListener('click', closeModal);
      overlay.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
    </script>
  </>
)}
