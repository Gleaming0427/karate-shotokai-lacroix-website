---
import { getCollection } from 'astro:content';

const events = await getCollection('evenements');
events.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<section class="section" id="evenements">
  <div class="container">
    <h2 class="section-title">Événements à venir</h2>

    {events.length === 0 ? (
      <p style="text-align: center; color: var(--color-text-soft);">Aucun événement à venir.</p>
    ) : (
      <div class="events-scroll">
        {events.map(event => (
          <article
            class="event-card"
            data-image={event.data.image || ''}
            data-tag={event.data.tag}
            data-title={event.data.title}
            data-desc={event.body || ''}
            style="cursor: pointer;"
          >
            {event.data.image && (
              <img src={event.data.image} alt={event.data.title} loading="lazy" />
            )}
            <div class="event-card-body">
              <span class="event-tag">{event.data.tag}</span>
              <h3>{event.data.title}</h3>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</section>

<div class="event-modal" id="event-modal">
  <div class="event-modal-card">
    <button class="event-modal-close" id="event-modal-close">&times;</button>
    <img src="" alt="" id="em-img" />
    <div class="event-modal-body">
      <span class="event-tag" id="em-tag"></span>
      <h3 id="em-title"></h3>
      <p id="em-desc"></p>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById('event-modal')!;
  const emImg = document.getElementById('em-img') as HTMLImageElement;
  const emTag = document.getElementById('em-tag')!;
  const emTitle = document.getElementById('em-title')!;
  const emDesc = document.getElementById('em-desc')!;

  document.querySelectorAll('.event-card').forEach(card => {
    card.addEventListener('click', () => {
      const img = card.getAttribute('data-image');
      if (img) { emImg.src = img; emImg.style.display = 'block'; }
      else { emImg.style.display = 'none'; }
      emTag.textContent = card.getAttribute('data-tag') || '';
      emTitle.textContent = card.getAttribute('data-title') || '';
      emDesc.textContent = card.getAttribute('data-desc') || '';
      modal.classList.add('open');
      document.body.style.overflow = 'hidden';
    });
  });

  function close() { modal.classList.remove('open'); document.body.style.overflow = ''; }
  document.getElementById('event-modal-close')?.addEventListener('click', close);
  modal.addEventListener('click', (e) => { if (e.target === modal) close(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
</script>
