---
const b = import.meta.env.BASE_URL;
const base = b === "/" ? "" : b;
const serignanImg = `${base}/images/serignan-2026.jpg`;
---

<section class="section" id="evenements">
  <div class="container">
    <h2 class="section-title">Événements à venir</h2>

    <div class="events-scroll">
      <!-- Stage Sérignan -->
      <article class="event-card" id="event-serignan" style="cursor: pointer;">
        <img src={serignanImg} alt="Stage Sérignan 2026" loading="lazy" />
        <div class="event-card-body">
          <span class="event-tag">Stage national</span>
          <h3>Stage à Sérignan</h3>
          <p>Du 06 au 10 juillet 2026<br/>Organisé par la KDSE. Ouvert à tous les adhérents.</p>
        </div>
      </article>

    </div>
  </div>
</section>

<!-- Lightbox -->
<div class="modal-overlay" id="modal-overlay">
  <div class="modal-content">
    <button class="modal-close" id="modal-close">&times;</button>
    <img src={serignanImg} alt="Stage Sérignan 2026" id="modal-img" />
  </div>
</div>

<script>
  const overlay = document.getElementById('modal-overlay')!;
  const card = document.getElementById('event-serignan');
  const close = document.getElementById('modal-close')!;

  card?.addEventListener('click', () => {
    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';
  });

  function closeModal() {
    overlay.classList.remove('open');
    document.body.style.overflow = '';
  }

  close.addEventListener('click', closeModal);
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) closeModal();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>
