---
const b = import.meta.env.BASE_URL;
const base = b === "/" ? "" : b;
const urlHoraires = `${base}/#horaires`;
---

<section class="hero" id="hero">
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <div class="hero-logo" role="img" aria-label="Karaté Shotokaï &amp; Iaijutsu Lacroix Falgarde"></div>
    <h1><a href={urlHoraires}>Karaté Shotokaï &amp; Iaijutsu</a></h1>
    <p class="hero-tagline">Accessible à toutes et à tous, aux petits comme aux grands&nbsp;!</p>
    <a href={urlHoraires} class="btn">Horaires et tarifs</a>
  </div>
</section>
