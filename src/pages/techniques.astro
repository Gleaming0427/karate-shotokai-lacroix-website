---
const b = import.meta.env.BASE_URL;
const base = b === "/" ? "" : b;
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="icon" type="image/png" href={`${base}/favicon.png`} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <meta name="generator" content={Astro.generator} />

    <title>Techniques — Karaté Shotokaï & Iaijutsu</title>
    <meta name="description" content="Techniques de Karaté-do Shotokaï et Iaijutsu — Lacroix-Falgarde." />
    <link rel="canonical" href={`${base}/techniques/`} />
    <meta name="robots" content="index, follow" />

    <meta property="og:title" content="Techniques — Karaté Shotokaï & Iaijutsu" />
    <meta property="og:description" content="Techniques de Karaté-do Shotokaï et Iaijutsu." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${base}/techniques/`} />
    <meta property="og:locale" content="fr_FR" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Techniques — Karaté Shotokaï & Iaijutsu" />
  </head>

  <body class="page-inner">
    <a href="#main" class="skip-link">Aller au contenu</a>
    <Header />
    <main id="main">
      <section class="section" style="padding-top: 8rem; min-height: 70vh; display: flex; align-items: center; justify-content: center; text-align: center;">
        <div class="container">
          <h1 class="section-title" style="text-transform: none; letter-spacing: 0.04em;">Techniques</h1>
          <p style="color: var(--color-text-soft);">À venir prochainement.</p>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
